# Copy this file to .env and adjust paths for your machine.
# .env is gitignored — never commit it.

# GitHub token for NuGet restore from GitHub Packages (required)
GITHUB_TOKEN=your_token_here

# ── Game paths ──────────────────────────────────────────────────────────────
# Uncomment and use the block matching your OS.

# Windows (default Steam install path):
#
# GAME_DIR=C:/Program Files (x86)/Steam/steamapps/common/Schedule I
# MONO_MANAGED=C:/Program Files (x86)/Steam/steamapps/common/Schedule I/Schedule I_Data/Managed
# MELONLOADER_MONO=C:/Program Files (x86)/Steam/steamapps/common/Schedule I/MelonLoader/net35
# MELONLOADER_IL2CPP=C:/Program Files (x86)/Steam/steamapps/common/Schedule I/MelonLoader/net6
# IL2CPP_ASSEMBLIES=C:/Program Files (x86)/Steam/steamapps/common/Schedule I/MelonLoader/Il2CppAssemblies
# MODS_DIR=C:/Program Files (x86)/Steam/steamapps/common/Schedule I/Mods

# Linux (Windows drive mounted at /mnt/windows):
#
# GAME_DIR=/mnt/windows/Program Files (x86)/Steam/steamapps/common/Schedule I
# MONO_MANAGED=/mnt/windows/Program Files (x86)/Steam/steamapps/common/Schedule I/Schedule I_Data/Managed
# MELONLOADER_MONO=/mnt/windows/Program Files (x86)/Steam/steamapps/common/Schedule I/MelonLoader/net35
# MELONLOADER_IL2CPP=/mnt/windows/Program Files (x86)/Steam/steamapps/common/Schedule I/MelonLoader/net6
# IL2CPP_ASSEMBLIES=/mnt/windows/Program Files (x86)/Steam/steamapps/common/Schedule I/MelonLoader/Il2CppAssemblies
# MODS_DIR=/mnt/windows/Program Files (x86)/Steam/steamapps/common/Schedule I/Mods
