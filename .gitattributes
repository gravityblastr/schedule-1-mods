# Normalize line endings to LF in the repo and on checkout.
* text=auto eol=lf

# Explicit LF for text formats
*.cs        text eol=lf
*.csproj    text eol=lf
*.props     text eol=lf
*.targets   text eol=lf
*.sln       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.json      text eol=lf
*.toml      text eol=lf
*.md        text eol=lf
*.bbcode    text eol=lf
*.txt       text eol=lf
.env*       text eol=lf

# Binary — never touch line endings
*.dll    binary
*.png    binary
*.svg    binary
*.nupkg  binary
